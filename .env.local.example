# Backend URL (change if backend runs on different port)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000/api

# GitHub OAuth Configuration
# Get these from https://github.com/settings/developers
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# Redirect URL for GitHub OAuth (for production, change to your domain)
# NEXT_PUBLIC_GITHUB_REDIRECT_URI=https://yourdomain.com/auth/callback
